{
  "manifest_version": 3,
  "name": "Analytical Design",
  "short_name": "AnalyticalD",
  "version": "2.0.0",
  "description": "Analyze thumbnails, logos, and creative projects across YouTube, Behance, Pinterest, and Dribbble. Extract color palettes and generate conceptual AI-ready prompts locally.",

  "action": {
    "default_popup": "popup.html"
  },

  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://*.youtube.com/*",
    "https://*.ytimg.com/*",
    "https://*.behance.net/*",
    "https://*.be.net/*",
    "https://*.pinterest.com/*",
    "https://*.pinimg.com/*",
    "https://*.dribbble.com/*",
    "https://*.dribbbleusercontent.com/*"
  ]
}